# PlaceMate AI Backend Environment Variables
PORT=5000

# MongoDB Connection String (Atlas URI or Local URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/placemate?retryWrites=true&w=majority

# JWT Token Configuration (For secure authentication)
JWT_SECRET=super_secret_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Google Gemini API key (Required for secure AI modules)
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary Credentials (For storing user uploaded resumes)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend App URL (For CORS validation)
FRONTEND_URL=http://localhost:5173
